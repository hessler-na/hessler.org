---
interface Props {
  hostedButtonId: string
}

const { hostedButtonId } = Astro.props
---

<div id="donate-button-container">
  <div id="donate-button"></div>
  <script src="https://www.paypalobjects.com/donate/sdk/donate-sdk.js" charset="UTF-8" is:inline></script>
  <script is:inline define:vars={{ hostedButtonId }}>
    const renderPayPalButton = () => {
      const container = document.getElementById('donate-button');
      if (container && window.PayPal) {
        container.innerHTML = '';
        PayPal.Donation.Button({
          env:'production',
          hosted_button_id:hostedButtonId,
          image: {
            src:'https://www.paypalobjects.com/en_US/i/btn/btn_donate_LG.gif',
            alt:'Donate with PayPal button',
            title:'PayPal - The safer, easier way to pay online!',
          }
        }).render('#donate-button');
      }
    };

    renderPayPalButton();

    document.addEventListener('astro:page-load', renderPayPalButton);
  </script>
</div>

<style>
  #donate-button-container {
    display: flex;
    justify-content: center;
    margin: 2rem 0;
  }
</style>